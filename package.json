    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.7",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.1",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "typescript": "^5.7.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
